      "name": "GET_All_Users_Positive",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verify that the response status code is 200\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Convert response to JSON\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Verify that the response contains users\r",
              "pm.test(\"Users array is not empty\", function () {\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Verify that the response is an array\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
